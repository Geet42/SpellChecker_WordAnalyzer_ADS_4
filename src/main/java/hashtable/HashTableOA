package hashtable;

import adt.Entry;
import adt.MapADT;

import java.util.ArrayList;
import java.util.List;

/**
 * Hash Table with Open Addressing: implements MapADT.
 *
 * Instead of chaining, collisions are resolved by probing for the next
 * available slot within the table itself.
 *
 * Two probing strategies:
 * - Linear Probing: h(k, i) = (h(k) + i) mod N
 *   Simple but suffers from primary clustering.
 *
 * - Double Hashing: h(k, i) = (h1(k) + i * h2(k)) mod N
 *   Uses a secondary hash to determine step size, reducing clustering.
 *   h2(k) = q - (hashCode(k) mod q), where q is a prime < N.
 *
 * Deleted entries are marked with a DEFUNCT sentinel to maintain probe sequences.
 * Rehashing occurs when load factor exceeds threshold.
 */
public class HashTableOA<K, V> implements MapADT<K, V> {

    public enum ProbingMethod {
        LINEAR_PROBING,
        DOUBLE_HASHING
    }

    // Sentinel for deleted slots
    private static final Entry<?, ?> DEFUNCT = new Entry<>(null, null);

    private Entry<K, V>[] table;
    private int size;
    private int capacity;
    private double loadFactorThreshold;
    private ProbingMethod probingMethod;

    // For double hashing: secondary prime
    private int secondaryPrime;

    // Performance tracking
    private long probeCount;
    private long operationCount;
    private int rehashCount;

    private static final int DEFAULT_CAPACITY = 16;
    private static final double DEFAULT_LOAD_FACTOR = 0.5; // lower for open addressing

    public HashTableOA() {
        this(DEFAULT_CAPACITY, DEFAULT_LOAD_FACTOR, ProbingMethod.LINEAR_PROBING);
    }

    public HashTableOA(int capacity, double loadFactorThreshold, ProbingMethod method) {
        this.capacity = capacity;
        this.loadFactorThreshold = loadFactorThreshold;
        this.probingMethod = method;
        this.table = new Entry[capacity];
        this.size = 0;
        this.probeCount = 0;
        this.operationCount = 0;
        this.rehashCount = 0;
        this.secondaryPrime = previousPrime(capacity);
    }

    // ---- Primary hash (Division Method) ----
    private int primaryHash(K key) {
        return (key.hashCode() & 0x7FFFFFFF) % capacity;
    }

    // ---- Secondary hash for Double Hashing ----
    // h2(k) = q - (hashCode(k) mod q), ensures h2 is never 0
    private int secondaryHash(K key) {
        return secondaryPrime - ((key.hashCode() & 0x7FFFFFFF) % secondaryPrime);
    }

    /**
     * Compute the probe index for the i-th probe.
     * Linear Probing:  (h1(k) + i) mod N
     * Double Hashing:  (h1(k) + i * h2(k)) mod N
     */
    private int probe(K key, int i) {
        int h1 = primaryHash(key);
        switch (probingMethod) {
            case DOUBLE_HASHING:
                int h2 = secondaryHash(key);
                return (h1 + i * h2) % capacity;
            case LINEAR_PROBING:
            default:
                return (h1 + i) % capacity;
        }
    }

    // ---- MapADT Operations ----

    @Override
    public V get(K key) {
        operationCount++;
        for (int i = 0; i < capacity; i++) {
            int idx = probe(key, i);
            probeCount++;
            if (table[idx] == null) {
                return null; // empty slot = key not in table
            }
            if (table[idx] != DEFUNCT && table[idx].getKey().equals(key)) {
                return table[idx].getValue();
            }
        }
        return null; // table full, key not found
    }

    @Override
    public V put(K key, V value) {
        operationCount++;

        if ((double) size / capacity >= loadFactorThreshold) {
            rehash();
        }

        int firstDefunct = -1;

        for (int i = 0; i < capacity; i++) {
            int idx = probe(key, i);
            probeCount++;

            if (table[idx] == null) {
                // Insert at first defunct slot if we found one, otherwise here
                int insertIdx = (firstDefunct != -1) ? firstDefunct : idx;
                table[insertIdx] = new Entry<>(key, value);
                size++;
                return null;
            }

            if (table[idx] == DEFUNCT) {
                if (firstDefunct == -1) firstDefunct = idx;
                continue;
            }

            if (table[idx].getKey().equals(key)) {
                V old = table[idx].getValue();
                table[idx].setValue(value);
                return old;
            }
        }

        // Should not reach here if load factor is managed
        if (firstDefunct != -1) {
            table[firstDefunct] = new Entry<>(key, value);
            size++;
        }
        return null;
    }

    @Override
    public V remove(K key) {
        operationCount++;
        for (int i = 0; i < capacity; i++) {
            int idx = probe(key, i);
            probeCount++;

            if (table[idx] == null) {
                return null;
            }
            if (table[idx] != DEFUNCT && table[idx].getKey().equals(key)) {
                V old = table[idx].getValue();
                table[idx] = (Entry<K, V>) DEFUNCT; // mark as defunct
                size--;
                return old;
            }
        }
        return null;
    }

    @Override
    public boolean containsKey(K key) {
        return get(key) != null;
    }

    @Override
    public int size() {
        return size;
    }

    @Override
    public boolean isEmpty() {
        return size == 0;
    }

    @Override
    public List<Entry<K, V>> entrySet() {
        List<Entry<K, V>> entries = new ArrayList<>();
        for (Entry<K, V> e : table) {
            if (e != null && e != DEFUNCT) entries.add(e);
        }
        return entries;
    }

    @Override
    public List<K> keySet() {
        List<K> keys = new ArrayList<>();
        for (Entry<K, V> e : entrySet()) keys.add(e.getKey());
        return keys;
    }

    @Override
    public List<V> values() {
        List<V> vals = new ArrayList<>();
        for (Entry<K, V> e : entrySet()) vals.add(e.getValue());
        return vals;
    }

    // ---- Rehashing ----

    private void rehash() {
        rehashCount++;
        Entry<K, V>[] oldTable = table;
        capacity = capacity * 2;
        table = new Entry[capacity];
        size = 0;
        secondaryPrime = previousPrime(capacity);

        for (Entry<K, V> e : oldTable) {
            if (e != null && e != DEFUNCT) {
                put(e.getKey(), e.getValue());
            }
        }
    }

    // ---- Performance Metrics ----

    public double getLoadFactor() {
        return (double) size / capacity;
    }

    public int getCapacity() {
        return capacity;
    }

    public double getAverageProbes() {
        return operationCount == 0 ? 0 : (double) probeCount / operationCount;
    }

    public int getRehashCount() {
        return rehashCount;
    }

    public long getOperationCount() {
        return operationCount;
    }

    /** Count of clusters (consecutive non-null runs) for clustering analysis. */
    public int getClusterCount() {
        int clusters = 0;
        boolean inCluster = false;
        for (Entry<K, V> e : table) {
            if (e != null && e != DEFUNCT) {
                if (!inCluster) {
                    clusters++;
                    inCluster = true;
                }
            } else {
                inCluster = false;
            }
        }
        return clusters;
    }

    /** Longest consecutive run of occupied slots (clustering metric). */
    public int getLongestCluster() {
        int maxRun = 0, currentRun = 0;
        for (Entry<K, V> e : table) {
            if (e != null && e != DEFUNCT) {
                currentRun++;
                if (currentRun > maxRun) maxRun = currentRun;
            } else {
                currentRun = 0;
            }
        }
        return maxRun;
    }

    public void resetCounters() {
        probeCount = 0;
        operationCount = 0;
    }

    // ---- Utility ----

    private static int previousPrime(int n) {
        int candidate = n - 1;
        if (candidate < 2) return 2;
        while (!isPrime(candidate)) candidate--;
        return candidate;
    }

    private static boolean isPrime(int n) {
        if (n < 2) return false;
        if (n == 2 || n == 3) return true;
        if (n % 2 == 0 || n % 3 == 0) return false;
        for (int i = 5; i * i <= n; i += 6) {
            if (n % i == 0 || n % (i + 2) == 0) return false;
        }
        return true;
    }

    @Override
    public String toString() {
        return "HashTableOA{size=" + size + ", capacity=" + capacity +
                ", loadFactor=" + String.format("%.2f", getLoadFactor()) +
                ", probing=" + probingMethod +
                ", avgProbes=" + String.format("%.2f", getAverageProbes()) +
                ", longestCluster=" + getLongestCluster() +
                ", rehashes=" + rehashCount + "}";
    }
}
